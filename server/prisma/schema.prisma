generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AboutContent {
  id            String   @id @default(uuid())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  founder_bio   String?  @db.Text
  founder_image String?
  founder_name  String?
  founder_title String?
  hero_image    String?
  hero_subtitle String?
  hero_title    String?
  mission       String?  @db.Text
  section_image String?
  story         String?  @db.Text
  values        String?  @db.Text
  vision        String?  @db.Text

  @@map("about_content")
}

model Article {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  title      String
  content    String   @db.Text
  author     String
  category   String?
  excerpt    String?  @db.Text
  image_url  String?
  published  Boolean? @default(false)
  featured   Boolean? @default(false)
  views      Int?     @default(0)

  @@index([published])
  @@index([featured])
  @@map("articles")
}

model Booking {
  id               String   @id @default(uuid())
  created_at       DateTime @default(now())
  name             String
  email            String
  phone            String?
  class_type       String?
  experience       String?
  preferred_date   String?
  preferred_time   String?
  special_requests String?
  status           String?  @default("pending")
  instructor       String?

  @@index([email])
  @@index([status])
  @@map("bookings")
}

model ContactContent {
  id            String   @id @default(uuid())
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  hero_title    String?
  hero_subtitle String?
  address       String?  @db.Text
  email         String?
  hours         String?
  phone         String?

  @@map("contact_content")
}

model GalleryImage {
  id          String  @id @default(uuid())
  date        String
  title       String
  url         String
  description String?
  views       Int?    @default(0)

  @@map("gallery_images")
}

model PopupSetting {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now())
  enabled     Boolean? @default(false)
  title       String?
  message     String?
  image       String?
  button_text String?
  button_url  String?
  delay       Int?     @default(0)

  @@map("popup_settings")
}

model Product {
  id               String   @id @default(uuid())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  name             String
  description      String?
  price            Float
  priceUSD         Float?
  image_url        String?
  category         String?
  whatsapp_message String?
  stock_quantity   Int?     @default(0)
  is_available     Boolean? @default(true)
  is_featured      Boolean? @default(false)
  buy_action       String?  @default("whatsapp")
  external_link    String?  @db.Text

  @@map("products")
}

model HomeContent {
  id               String   @id @default(uuid())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  heroTitle        String?
  heroSubtitle     String?
  heroImage        String?
  heroButtonText   String?
  heroStats        String?
  aboutTitle       String?
  aboutDescription String?
  aboutPhilosophy1 String?
  aboutPhilosophy2 String?
  aboutButtonText  String?
  aboutImage       String?
  aboutFeatures    String?

  @@map("home_content")
}

model File {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  name       String
  url        String
  size       String?
  type       String?
  dimensions String?
  uploadDate String?

  @@map("files")
}

model Instructor {
  id             String   @id @default(uuid())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  name           String
  title          String?
  specialization String?
  experience     String?
  certifications String?
  rating         Float?   @default(0)
  students       String?
  description    String?  @db.Text
  image          String?
  email          String?
  phone          String?
  instagram      String?
  facebook       String?
  twitter        String?
  linkedin       String?
  featured       Boolean? @default(false)
  signature_url  String?
  tiktok         String?
  connected_user String?

  @@index([featured])
  @@index([connected_user])
  @@map("instructors")
}

model OnlineClass {
  id             String   @id @default(uuid())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  title          String
  instructor     String?
  classStarting  String?
  description    String?  @db.Text
  price          String?
  priceUSD       String?
  duration       String?
  capacity       String?
  schedule       String?
  level          String?
  rating         Float?   @default(0)
  features       String?
  image          String?
  joinLink       String?
  maxSeats       Int?     @default(0)
  availableSeats Int?     @default(0)
  featured       Boolean? @default(false)

  @@index([featured])
  @@map("online_classes")
}

model PolicyPage {
  id         String   @id @default(uuid())
  type       String   @unique
  title      String
  content    String   @db.Text
  updated_at DateTime @updatedAt

  @@map("policy_pages")
}

model YogaCertificate {
  id             String   @id @default(uuid())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  certificateId  String   @unique
  studentName    String
  courseName     String
  issueDate      DateTime
  instructorName String
  phone          String?
  signature_url  String?

  @@map("yoga_certificates")
}

model User {
  id         String   @id
  username   String   @unique
  email      String   @unique
  password   String
  role       String   @default("user")
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model SeoSetting {
  id          String   @id @default(uuid())
  title       String
  description String
  keywords    String?
  robotsTxt   String?  @db.Text
  sitemapXml  String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("seo_settings")
}

model SiteSetting {
  id            String   @id @default(uuid())
  logoUrl       String?
  faviconUrl    String?
  socialLinks   String?  @db.Text
  businessName  String?
  businessEmail String?
  businessPhone String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("site_settings")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  date        String
  time        String
  location    String
  price       String
  image       String
  capacity    String
  joinUrl     String
  buttonText  String?
  buttonUrl   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("events")
}
